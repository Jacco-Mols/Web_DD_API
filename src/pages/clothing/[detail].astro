---
// @ts-nocheck
import '../../styles/global.css';
import '../../styles/vars.css';
import '../../styles/details.css';

import Header from '../../components/header.astro';
import Head from '../../components/head.astro';

const urlVillagers = "https://api.nookipedia.com/villagers?pagination[itemsPerPage]=50";
const Villagersresponse = await fetch(urlVillagers, {
    headers: {
        "X-API-KEY": import.meta.env.PUBLIC_NOOK_API_KEY,
        "Accept-Version": "1.0.0"
    }
});

const data = await Villagersresponse.json();
const villagers = data.slice(0, 100);

// astro.params van workshop met Jad
const character = Astro.params.detail

// Met hulp van Jad gemaakt, zoekt naar de villager met precies dezelfde naam als die van character
const details = villagers.find( villager => villager.name === character)

const urlClothes = "https://api.nookipedia.com/nh/clothing?pagination[itemsPerPage]=50";
const clothesResponse = await fetch(urlClothes, {
    headers: {
        "X-API-KEY": import.meta.env.PUBLIC_NOOK_API_KEY,
        "Accept-Version": "1.0.0"
    }
});

const clothesData = await clothesResponse.json();
const headwearFilter = clothesData.filter(clotheData => clotheData.category === 'Headwear')

// https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/Array/slice
const headwear = headwearFilter.slice(0, 50);
---

<html lang="en">
    <Head />
<body>
    <Header />
    <main>
        <section class="dress-character">
            <h1>{character}</h1>
            <div class="villager-container" >
                <div class="droppable" data-draggable-id="acorn knit cap"></div>
                
                <img src={details.image_url} alt={details.name} class="villager-img" />
            </div>
            <button class="save-outfit-button">Save outfit</button>

            <article class="headwear-container">
                <ul class="headwear">
                    {headwear.map(head => (
                        // LET OP: <li> en <img> moeten altijd aan elkaar verbonden zijn (zonder spaties)
                        // want we maken later gebruik van "li:empty"
                        <li><button class="drag-button"><img src={head.variations[0].image_url} alt={head.name} class='draggable'
                            draggable="true" id={`hat-${head.name}`}/></button></li>
                    ))}
                </ul>
                <button class="remove-items">Remove all items</button>
            </article>

        </section>
    </main>
    <footer></footer>
</body>

</html>

<script define:vars={ { details }}>
    // @ts-nocheck

    // https://codepen.io/Jacco01/pen/WbGPgmv - voorbeeld van drag n drop api
    const droppableElement = document.querySelectorAll('.droppable');
    const draggableElement = document.querySelectorAll('.draggable');

    const removeItemsButton = document.querySelector('.remove-items');
    const saveOutfitButton = document.querySelector('.save-outfit-button');

    let equippedItem = null;
    let originalPlace = null;

    draggableElement.forEach(item => {
        item.addEventListener('dragstart', dragStart);
        item.addEventListener('click', clickedItem);
    });

    droppableElement.forEach(item => {
        item.addEventListener('dragover', dragOver);
        item.addEventListener('drop', drop);
    });
    
    function dragStart(event) {
        event.dataTransfer.setData('text', event.target.id);
    };

    function dragOver(event) {
        event.preventDefault();
    };

    function saveOutfit(draggedEl) {

        // Voorbeeld van localstorage van workshop van Jad
        // const savedData = JSON.parse(localStorage.getItem("count"))

        // let value = savedData.counter;
        // const counter = document.querySelector('#counter');
        // const button = document.querySelector('#add');
        // button.addEventListener('click', () => {
        //     value = value + 1;
        //     counter.textContent = value;
        //     const data = {
        //         counter: value,
        //     };
        //     console.log(data)

        //     // counter opslaan
        //     localStorage.setItem("count", JSON.stringify(data));
        // });
        
        // Met hulp van AI
        // Prompt: How can I use LocalStorage to save two different elements and display it on another page? One element is from a content api the other from drag and drop api.
        const villagerName = details.name;
        const hatId = draggedEl.id;

        // creating outfit object from previous vars
        const outfit = {
            villager:  villagerName,
            outfit: hatId
        };

        // https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/JSON/parse
        // JSON.parse turns data into a object
        const savedOutfit = JSON.parse(localStorage.getItem('outfit')) || [];

        // Add new outfit
        savedOutfit.push(outfit);

        // Stringify turns data into a string
        localStorage.setItem('outfit', JSON.stringify(savedOutfit));
        console.log('Saved outfit', outfit);
    };

    function drop(event) {
        event.preventDefault();
        // Let op: niet altijd de echte dropZone
        const dropZone = event.target;
        const draggedItem = event.dataTransfer.getData('text');
        const dropId = event.target.getAttribute('data-draggable-id');
        const draggedEl = document.getElementById(draggedItem);

        // ul list of items
        const ogList = document.querySelector('.headwear');

        // remove item button
        const removeItemsButton = document.querySelector('.remove-items');
        removeItemsButton.classList.add('show');

        // Met hulp van Jad
        const droppedItem = document.querySelector(".droppable .dropped");
        if (droppedItem) {
            droppedItem.classList.remove("dropped");
            ogList.querySelector("button:empty").appendChild(droppedItem);
        };

        // appendChild - https://developer.mozilla.org/en-US/docs/Web/API/Node/appendChild
        // Moves element from current position to new position. You are adding a new child to a parent (parent.appendChild(child))
        document.querySelector(".droppable").appendChild(draggedEl);
        draggedEl.classList.add('dropped');

        equippedItem = draggedEl;
        originalPlace = ogList;

    };
    // Met hulp van Syd, stappen:
    // 1. zet buttons om de images zodat er ook een focus style is CHECK
    // 2. voeg een click event toe op de buttons, die de hoedjes op het karakter zet
    // 3. check of er al een hoedje op zit, en zorg dat het oude hoedje terug op zn plek komt als dat zo is
    function clickedItem(event) {
        const draggedEl = event.target;
        // Let op: niet altijd de echte dropZone
        const dropZone = document.querySelector('.droppable')
        const ogList = document.querySelector('.headwear');
        const removeItemsButton = document.querySelector('.remove-items');
        removeItemsButton.classList.add('show');

        // Met hulp van Jad
        const droppedItem = document.querySelector(".droppable .dropped");
        if (droppedItem) {
            droppedItem.classList.remove("dropped");
            ogList.querySelector("button:empty").appendChild(droppedItem);
        };

        dropZone.appendChild(draggedEl);
        draggedEl.classList.add('dropped');

        equippedItem = draggedEl;
        originalPlace = ogList;
    };

    // saves outfit on button click
    saveOutfitButton.addEventListener('click', () => {
        if(equippedItem) {
            saveOutfit(equippedItem);
            saveOutfitButton.classList.remove('button-click');

            saveOutfitButton.offsetWidth
            saveOutfitButton.classList.add('button-click');

        } else {
            console.log('no outfit!');
            saveOutfitButton.classList.remove('button-click');
        };
    });

    // returns equippeditem to list
    removeItemsButton.addEventListener('click', () => {
        equippedItem.classList.remove("dropped");
        originalPlace.querySelector("button:empty").appendChild(equippedItem);
        removeItemsButton.classList.remove('show'); 
    });

</script>